# Example application-local.yml configuration for local development
# Copy this file to application-local.yml (which is ignored by .gitignore)

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/javacore_local
    username: postgres
    password: postgres

app:
  security:
    jwt-secret: local-development-secret-key-must-be-at-least-32-bytes-long
